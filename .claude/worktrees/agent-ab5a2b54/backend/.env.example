# =============================================================================
# Spring Boot backend environment.
# Copy this file to backend/.env and fill in the secrets.
# DO NOT COMMIT backend/.env. It is gitignored.
# =============================================================================

# --- Supabase Postgres (direct connection string from Supabase dashboard) ---
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Supabase service-role secret key (sb_secret_...) -----------------------
# This is the service-role key used by the backend to bypass RLS.
SUPABASE_SECRET_KEY=

# --- Supabase JWT verification (JWKS endpoint) ------------------------------
# Default for project ref `szkbtkkqrzkkxedybths`. Override if pointing to another project.
SUPABASE_JWKS_URL=https://szkbtkkqrzkkxedybths.supabase.co/auth/v1/.well-known/jwks.json

# --- App-level overrides (optional) -----------------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
